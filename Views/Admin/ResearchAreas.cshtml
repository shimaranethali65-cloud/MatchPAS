@model IReadOnlyList<ResearchArea>
@{
    ViewData["Title"] = "Research areas";
}

<div class="bm-page-header d-flex flex-column flex-md-row justify-content-between align-items-start gap-3">
    <div>
        <h1 class="h2 mb-1">Research areas</h1>
        <p class="text-muted mb-0">Define areas used by students and supervisors for matching.</p>
    </div>
    <a class="btn btn-bm-primary" asp-action="CreateResearchArea"><i class="bi bi-plus-lg me-1"></i> Add area</a>
</div>

@if (Model.Count == 0)
{
    <div class="bm-card border-0 text-center py-5 px-3">
        <i class="bi bi-diagram-3 display-4 text-muted mb-3 d-block"></i>
        <p class="text-muted mb-4">No research areas yet. Add the first one to enable proposals.</p>
        <a class="btn btn-bm-primary" asp-action="CreateResearchArea">Add research area</a>
    </div>
}
else
{
    <div class="table-responsive bm-card border-0">
        <table class="table table-hover table-bm mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <td class="fw-medium">@a.Name</td>
                        <td class="text-muted small">@(a.Description ?? "—")</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-primary" asp-action="EditResearchArea" asp-route-id="@a.Id">Edit</a>
                            <form asp-action="DeleteResearchArea" asp-route-id="@a.Id" method="post" class="d-inline"
                                  data-bm-confirm
                                  data-bm-title="Delete research area?"
                                  data-bm-message="This removes the area from the catalog. Existing proposals that use it may be affected."
                                  data-bm-variant="danger">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="mt-4 d-flex flex-wrap gap-2">
    <a asp-action="SupervisorAreas" class="btn btn-outline-primary"><i class="bi bi-people me-1"></i> Assign supervisor areas</a>
    <a asp-action="Matches" class="btn btn-outline-primary"><i class="bi bi-link-45deg me-1"></i> View all matches</a>
</div>
