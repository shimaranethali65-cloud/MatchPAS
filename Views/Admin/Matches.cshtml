@model AdminMatchesDashboardDto
@{
    ViewData["Title"] = "Matches";
    var hasAny = Model.ConfirmedMatches.Count > 0 || Model.SubmittedAwaitingMatch.Count > 0;
}

<div class="bm-page-header d-flex flex-column flex-md-row justify-content-between align-items-start gap-3">
    <div>
        <h1 class="h2 mb-1">Matches &amp; queue</h1>
        <p class="text-muted mb-0">Confirmed matches and submitted proposals still waiting for a supervisor to confirm.</p>
    </div>
    <a class="btn btn-outline-primary" asp-action="ResearchAreas"><i class="bi bi-diagram-3 me-1"></i> Research areas</a>
</div>

@if (!hasAny)
{
    <div class="bm-card border-0 text-center py-5 px-3">
        <i class="bi bi-link-45deg display-4 text-muted mb-3 d-block"></i>
        <p class="text-muted mb-2">No submitted proposals and no confirmed matches yet.</p>
        <p class="small text-muted mb-0">Students must <strong>submit</strong> a proposal; supervisors must <strong>confirm match</strong> before a row appears under Confirmed matches.</p>
    </div>
}
else
{
    @if (Model.SubmittedAwaitingMatch.Count > 0)
    {
        <h2 class="h5 mb-3"><i class="bi bi-hourglass-split text-warning me-1"></i> Submitted — awaiting supervisor match</h2>
        <div class="table-responsive bm-card border-0 mb-5">
            <table class="table table-hover table-bm mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Proposal</th>
                        <th>Area</th>
                        <th>Student</th>
                        <th>Last updated</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.SubmittedAwaitingMatch)
                    {
                        <tr>
                            <td class="fw-medium">@p.Title</td>
                            <td><span class="badge rounded-pill bg-light text-dark border">@p.ResearchAreaName</span></td>
                            <td class="small">@p.StudentEmail</td>
                            <td class="text-muted small text-nowrap">@p.LastUpdated.LocalDateTime.ToString("g")</td>
                            <td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-action="MatchIntervention" asp-route-id="@p.ProposalId">Override</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <h2 class="h5 mb-3"><i class="bi bi-check2-circle text-success me-1"></i> Confirmed matches</h2>
    @if (Model.ConfirmedMatches.Count == 0)
    {
        <div class="bm-card border-0 py-4 px-3 mb-0">
            <p class="text-muted mb-0 small">No supervisor has confirmed a match yet. When they do, rows will appear here.</p>
        </div>
    }
    else
    {
        <div class="table-responsive bm-card border-0">
            <table class="table table-hover table-bm mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Proposal</th>
                        <th>Area</th>
                        <th>Student</th>
                        <th>Supervisor</th>
                        <th>Matched</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model.ConfirmedMatches)
                    {
                        <tr>
                            <td class="fw-medium">@m.ProposalTitle</td>
                            <td><span class="badge rounded-pill bg-light text-dark border">@m.ResearchAreaName</span></td>
                            <td class="small">@m.StudentEmail</td>
                            <td class="small">@m.SupervisorEmail</td>
                            <td class="text-muted small text-nowrap">@m.MatchedAt.LocalDateTime.ToString("g")</td>
                            <td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-action="MatchIntervention" asp-route-id="@m.ProposalId">Override</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}
