@model EditUserRolesViewModel
@{
    ViewData["Title"] = "Edit roles";
}

<div class="bm-page-header">
    <h1 class="h2 mb-1">Edit roles</h1>
    <p class="text-muted mb-0"><a asp-action="Users">Back to users</a></p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="bm-card border-0 p-4">
            <p class="small text-muted mb-3">
                <strong>@Model.Email</strong>
                @if (!string.IsNullOrWhiteSpace(Model.DisplayName))
                {
                    <span>· @Model.DisplayName</span>
                }
            </p>
            <form asp-action="EditUserRoles" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="DisplayName" />
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                <div class="form-check mb-2">
                    <input asp-for="IsStudent" class="form-check-input" />
                    <label asp-for="IsStudent" class="form-check-label"></label>
                </div>
                <div class="form-check mb-2">
                    <input asp-for="IsSupervisor" class="form-check-input" />
                    <label asp-for="IsSupervisor" class="form-check-label"></label>
                </div>
                <div class="form-check mb-4">
                    <input asp-for="IsAdmin" class="form-check-input" />
                    <label asp-for="IsAdmin" class="form-check-label"></label>
                </div>
                <button type="submit" class="btn btn-bm-primary">Save</button>
            </form>
        </div>
    </div>
</div>
