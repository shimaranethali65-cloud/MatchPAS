@model IReadOnlyList<AdminUserRowViewModel>
@{
    ViewData["Title"] = "Users";
}

<div class="bm-page-header d-flex flex-column flex-md-row justify-content-between align-items-start gap-3">
    <div>
        <h1 class="h2 mb-1">Users</h1>
        <p class="text-muted mb-0">Create accounts and assign roles.</p>
    </div>
    <a class="btn btn-bm-primary" asp-action="CreateUser"><i class="bi bi-person-plus me-1"></i> New user</a>
</div>

<div class="table-responsive bm-card border-0">
    <table class="table table-hover table-bm mb-0">
        <thead class="table-light">
            <tr>
                <th>Email</th>
                <th>Display name</th>
                <th>Roles</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td class="small">@u.Email</td>
                    <td class="small">@(u.DisplayName ?? "—")</td>
                    <td class="small">@u.RolesSummary</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="EditUserRoles" asp-route-id="@u.Id">Roles</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
