@model ResearchAreaFormViewModel
@{
    ViewData["Title"] = "Edit research area";
}

<div class="bm-page-header">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb small mb-2">
            <li class="breadcrumb-item"><a asp-action="ResearchAreas">Research areas</a></li>
            <li class="breadcrumb-item active">Edit</li>
        </ol>
    </nav>
    <h1 class="h2 mb-1">Edit research area</h1>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="bm-card border-0 p-4 p-md-5">
            <form asp-action="EditResearchArea" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control form-control-lg" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-semibold"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-bm-primary btn-lg">Save</button>
                    <a class="btn btn-outline-secondary btn-lg" asp-action="ResearchAreas">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
