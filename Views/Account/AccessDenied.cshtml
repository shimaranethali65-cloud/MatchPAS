@{
    ViewData["Title"] = "Access denied";
}

<div class="text-center py-5">
    <div class="bm-icon-circle mx-auto mb-4" style="width: 4rem; height: 4rem;">
        <i class="bi bi-shield-lock fs-2"></i>
    </div>
    <h1 class="h3 mb-3">You do not have access to this page</h1>
    <p class="text-muted col-md-8 mx-auto mb-4">Your account is signed in, but this area requires a different role. Contact an administrator if you need access.</p>
    <a class="btn btn-bm-primary" asp-controller="Home" asp-action="Index">Go home</a>
</div>
