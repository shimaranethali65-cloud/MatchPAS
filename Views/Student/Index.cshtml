@model IReadOnlyList<ProjectProposal>
@{
    ViewData["Title"] = "My proposals";
}

<div class="bm-page-header d-flex flex-column flex-md-row justify-content-between align-items-start gap-3">
    <div>
        <h1 class="h2 mb-1">My proposals</h1>
        <p class="text-muted mb-0">Create drafts, submit for blind review, and track status.</p>
    </div>
    <a class="btn btn-bm-primary" asp-action="Create"><i class="bi bi-plus-lg me-1"></i> New proposal</a>
</div>

@if (Model.Count == 0)
{
    <div class="bm-card border-0 text-center py-5 px-3">
        <i class="bi bi-inbox display-4 text-muted mb-3 d-block"></i>
        <p class="text-muted mb-4">You have no proposals yet. Start with a draft.</p>
        <a class="btn btn-bm-primary" asp-action="Create">Create proposal</a>
    </div>
}
else
{
    <div class="table-responsive bm-card border-0">
        <table class="table table-hover table-bm mb-0">
            <thead class="table-light">
                <tr>
                    <th>Title</th>
                    <th>Area</th>
                    <th>Status</th>
                    <th>Updated</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td class="fw-medium">@p.Title</td>
                        <td><span class="badge rounded-pill bg-light text-dark border">@(p.ResearchArea?.Name ?? "—")</span></td>
                        <td>@await Html.PartialAsync("_ProposalStatusBadge", p.Status)</td>
                        <td class="text-muted small">@p.UpdatedAt.LocalDateTime.ToString("g")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@p.Id">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
