@model StudentProposalFormViewModel
@{
    ViewData["Title"] = "Edit proposal";
}

<div class="bm-page-header">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb small mb-2">
            <li class="breadcrumb-item"><a asp-action="Index">My proposals</a></li>
            <li class="breadcrumb-item"><a asp-action="Details" asp-route-id="@Model.Id">Details</a></li>
            <li class="breadcrumb-item active">Edit</li>
        </ol>
    </nav>
    <h1 class="h2 mb-1">Edit proposal</h1>
    <p class="text-muted mb-0">Changes apply while the proposal is not matched or withdrawn.</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="bm-card border-0 p-4 p-md-5">
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <div class="mb-3">
                    <label asp-for="ResearchAreaId" class="form-label fw-semibold"></label>
                    <select asp-for="ResearchAreaId" class="form-select form-select-lg" asp-items="@(new SelectList(Model.ResearchAreas, "Id", "Name"))">
                        <option value="">Choose a research area</option>
                    </select>
                    <span asp-validation-for="ResearchAreaId" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold"></label>
                    <input asp-for="Title" class="form-control form-control-lg" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Abstract" class="form-label fw-semibold"></label>
                    <textarea asp-for="Abstract" class="form-control" rows="8"></textarea>
                    <span asp-validation-for="Abstract" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="TechStack" class="form-label fw-semibold"></label>
                    <textarea asp-for="TechStack" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="TechStack" class="text-danger small"></span>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-bm-primary btn-lg">Save changes</button>
                    <a class="btn btn-outline-secondary btn-lg" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
