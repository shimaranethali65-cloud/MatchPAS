@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <div class="bm-icon-circle mx-auto mb-4" style="width: 4rem; height: 4rem; background: rgba(220, 53, 69, 0.12); color: #dc3545;">
        <i class="bi bi-exclamation-octagon fs-2"></i>
    </div>
    <h1 class="h3 text-danger mb-2">Something went wrong</h1>
    <p class="text-muted col-md-8 mx-auto mb-4">An error occurred while processing your request.</p>
    @if (Model.ShowRequestId)
    {
        <p class="small"><span class="text-muted">Request ID:</span> <code>@Model.RequestId</code></p>
    }
    <a class="btn btn-bm-primary" asp-controller="Home" asp-action="Index">Go home</a>
</div>
