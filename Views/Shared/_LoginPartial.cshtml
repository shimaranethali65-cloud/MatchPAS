@using Microsoft.AspNetCore.Identity
@using BlindMatchPAS.Models
@inject SignInManager<ApplicationUser> SignInManager

<ul class="navbar-nav bm-navbar-auth ms-md-auto">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle bm-navbar-user text-white d-flex align-items-center gap-2 rounded-pill px-2 px-md-3" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <span class="bm-navbar-avatar d-inline-flex align-items-center justify-content-center" aria-hidden="true">
                    <i class="bi bi-person-fill"></i>
                </span>
                <span class="d-none d-md-inline text-truncate fw-medium" style="max-width: 12rem;">@(User.Identity?.Name)</span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end bm-navbar-dropdown shadow-lg border-0">
                <li><span class="dropdown-item-text small text-muted">Signed in</span></li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                    <form class="px-3" asp-controller="Account" asp-action="Logout" method="post"
                          data-bm-confirm
                          data-bm-title="Log out?"
                          data-bm-message="You will need to sign in again to access your account."
                          data-bm-variant="danger">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">Log out</button>
                    </form>
                </li>
            </ul>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link bm-navbar-link-secondary rounded-pill px-3" asp-controller="Account" asp-action="Login">Log in</a>
        </li>
        <li class="nav-item">
            <a class="btn btn-sm bm-navbar-cta" asp-controller="Account" asp-action="Register">Register</a>
        </li>
    }
</ul>
